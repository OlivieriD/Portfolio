# HTTP fallback to ensure the site reachable even if SSL is rate-limited
http://olivierdportfolio.me {
    handle /api/* {
        reverse_proxy backend:8080
    }
    reverse_proxy frontend:80
}

olivierdportfolio.me {
    tls {
        issuer zerossl
    }
    
    # Route API requests to the backend container
    handle /api/* {
        reverse_proxy backend:8080
    }

    # Route everything else to the frontend container
    reverse_proxy frontend:80
}
