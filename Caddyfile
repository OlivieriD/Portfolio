# Ultimate Cloudflare-Friendly Config
# Put Cloudflare SSL/TLS to "Flexible"
:80, http://olivierdportfolio.me, http://www.olivierdportfolio.me, http://localhost {
    # Route API requests to the backend container
    handle /api/* {
        reverse_proxy backend:8080
    }

    # Route everything else to the frontend container
    reverse_proxy frontend:80
}
